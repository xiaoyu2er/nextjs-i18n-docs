{
  "name": "@next-i18n/translate",
  "version": "1.0.0",
  "description": "Translate nextjs documentation",
  "type": "module",
  "main": "dist/batch.pipeline.js",
  "module": "dist/batch.pipeline.js",
  "types": "dist/batch.pipeline.d.ts",
  "bin": {
    "translate-docs": "dist/batch.pipeline.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "bun run src/batch.pipeline.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --apply .",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/glob": "^8.1.0",
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^3.2.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "glob": "^11.0.2",
    "openai": "^5.1.1",
    "remark": "^15.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
