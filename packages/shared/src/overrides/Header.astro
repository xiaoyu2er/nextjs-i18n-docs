---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const pathname = Astro.url.pathname;
const isLearn = pathname.startsWith('/learn') || pathname.match(/^\/[a-z-]+\/learn/);
const isBlog = pathname.startsWith('/blog') || pathname.match(/^\/[a-z-]+\/blog/);
const isDocs = !isLearn && !isBlog;

const navLinks = [
  { href: '/docs/app/getting-started/installation/', label: 'Docs', active: isDocs },
  { href: '/learn/', label: 'Learn', active: isLearn },
  { href: '/blog/', label: 'Blog', active: isBlog },
];
---

<div class="header">
  <div class="header-title">
    <SiteTitle />
  </div>
  <nav class="header-nav sl-hidden md:sl-flex">
    {navLinks.map(({ href, label, active }) => (
      <a href={href} class:list={['header-nav-link', { 'header-nav-active': active }]}>{label}</a>
    ))}
  </nav>
  <div class="header-spacer"></div>
  {shouldRenderSearch && <div class="print:hidden"><Search /></div>}
  <div class="header-right sl-hidden md:sl-flex print:hidden">
    <SocialIcons />
    <div class="header-divider"></div>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<style is:global>
  .header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .header-title {
    flex-shrink: 0;
  }
  .header-nav {
    gap: 0.25rem;
    align-items: center;
    margin-inline-start: 0.5rem;
  }
  /* Override sl-hidden when md:sl-flex is active */
  .header-nav[class*="md:sl-flex"] {
    gap: 0.25rem;
    align-items: center;
  }
  .header-spacer {
    flex: 1;
  }
  .header-right {
    gap: 1rem;
    align-items: center;
  }
  .header-divider {
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }
  a.header-nav-link {
    padding: 0.35rem 0.625rem;
    border-radius: 0.375rem;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s, background-color 0.15s;
  }
  a.header-nav-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }
  a.header-nav-active {
    color: var(--sl-color-text-accent);
    background-color: var(--sl-color-accent-low);
  }
</style>
