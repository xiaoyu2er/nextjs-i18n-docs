---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const pathname = Astro.url.pathname;
const isLearn = pathname.startsWith('/learn') || pathname.match(/^\/[a-z-]+\/learn/);
const isBlog = pathname.startsWith('/blog') || pathname.match(/^\/[a-z-]+\/blog/);
const isDocs = !isLearn && !isBlog;

// Extract locale prefix from current URL (e.g., /zh-hans/docs/... → /zh-hans)
const localeMatch = pathname.match(/^\/([a-z]{2}(?:-[a-z]+)?)(?:\/|$)/);
const localePrefix = localeMatch ? `/${localeMatch[1]}` : '';

const navLinks = [
  { href: `${localePrefix}/docs/app/getting-started/installation/`, label: 'Docs', active: isDocs },
  { href: `${localePrefix}/learn/`, label: 'Learn', active: isLearn },
  { href: `${localePrefix}/blog/`, label: 'Blog', active: isBlog },
];
---

<div class="header">
  <div class="header-title">
    <SiteTitle />
  </div>
  <nav class="header-nav">
    {navLinks.map(({ href, label, active }) => (
      <a href={href} class:list={['header-nav-link', { 'header-nav-active': active }]}>{label}</a>
    ))}
  </nav>
  <div class="header-spacer"></div>
  {shouldRenderSearch && <div class="print:hidden"><Search /></div>}
  <div class="header-right print:hidden">
    <SocialIcons />
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>
<nav class="mobile-nav">
  {navLinks.map(({ href, label, active }) => (
    <a href={href} class:list={['mobile-nav-link', { 'mobile-nav-active': active }]}>{label}</a>
  ))}
</nav>

<style is:global>
  .header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }
  .header-title {
    flex-shrink: 0;
  }
  /* Desktop nav — hidden on mobile */
  .header-nav {
    display: none;
    gap: 0.25rem;
    align-items: center;
  }
  @media (min-width: 50rem) {
    .header-nav { display: flex; }
  }
  .header-spacer {
    flex: 1;
  }
  /* Desktop right controls — hidden on mobile (available via Starlight's mobile menu) */
  .header-right {
    display: none;
    gap: 0.75rem;
    align-items: center;
  }
  @media (min-width: 50rem) {
    .header-right { display: flex; }
  }
  a.header-nav-link {
    padding: 0.35rem 0.625rem;
    border-radius: 0.375rem;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s, background-color 0.15s;
  }
  a.header-nav-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }
  a.header-nav-active {
    color: var(--sl-color-text-accent);
    background-color: var(--sl-color-accent-low);
  }

  /* Mobile nav links — visible below md breakpoint */
  .mobile-nav {
    display: flex;
    gap: 0.25rem;
    padding: 0.25rem 0.75rem;
    border-top: 1px solid var(--sl-color-gray-6);
  }
  @media (min-width: 50rem) {
    .mobile-nav { display: none; }
  }
  .mobile-nav-link {
    padding: 0.375rem 0.625rem;
    border-radius: 0.375rem;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 0.15s, background-color 0.15s;
  }
  .mobile-nav-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }
  .mobile-nav-active {
    color: var(--sl-color-text-accent);
    background-color: var(--sl-color-accent-low);
  }
</style>
