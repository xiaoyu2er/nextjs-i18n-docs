---
const { src, caption, width, height, ...rest } = Astro.props;
---
{src && (
  <figure>
    <video
      src={src}
      width={width}
      height={height}
      autoplay
      loop
      muted
      playsinline
      style="width: 100%; height: auto; border-radius: 8px;"
    />
    {caption && (
      <figcaption style="text-align: center; margin-top: 0.5rem;">
        {caption}
      </figcaption>
    )}
  </figure>
)}
