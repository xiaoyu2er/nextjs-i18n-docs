---
const { src, srcLight, srcDark, alt, width, height, ...rest } = Astro.props;
const BLOB_BASE = 'https://h8DxKfmAPhn8O0p3.public.blob.vercel-storage.com';

function resolveUrl(path: string | undefined): string | undefined {
  if (!path) return undefined;
  if (path.startsWith('http')) return path;
  return `${BLOB_BASE}${path}`;
}

const lightSrc = resolveUrl(srcLight || src);
const darkSrc = resolveUrl(srcDark);
const hasThemeVariants = lightSrc && darkSrc;
---

{hasThemeVariants ? (
  <figure class="themed-image">
    <img
      src={lightSrc}
      alt={alt || ''}
      width={width}
      height={height}
      loading="lazy"
      decoding="async"
      class="rounded-md border border-gray-200 bg-gray-100"
      data-light
    />
    <img
      src={darkSrc}
      alt={alt || ''}
      width={width}
      height={height}
      loading="lazy"
      decoding="async"
      class="rounded-md border border-gray-200 bg-gray-100"
      data-dark
    />
  </figure>
) : lightSrc ? (
  <img
    src={lightSrc}
    alt={alt || ''}
    width={width}
    height={height}
    loading="lazy"
    decoding="async"
    class="rounded-md border border-gray-200 bg-gray-100"
  />
) : null}

<style is:global>
  .themed-image img[data-dark] {
    display: none;
  }
  .themed-image img[data-light] {
    display: block;
  }
  [data-theme='dark'] .themed-image img[data-light] {
    display: none;
  }
  [data-theme='dark'] .themed-image img[data-dark] {
    display: block;
  }
</style>
