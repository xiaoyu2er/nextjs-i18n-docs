{
  "name": "next-i18n-docs",
  "version": "1.0.0",
  "description": "Next.js documentation translated into 9 languages, deployed on Cloudflare Workers",
  "main": "index.js",
  "scripts": {
    "postinstall": "pnpm run build:packages",
    "format": "biome format --write .",
    "build:packages": "pnpm --filter @next-i18n/const --filter @next-i18n/utils --filter @next-i18n/translate --filter @next-i18n/crawler build",
    "test": "pnpm -r test",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "dev": "cd apps/router && bun run dev-all.ts",
    "dev:latest": "cd apps/web && bun run dev",
    "dev:v": "cd apps/web-v && VERSION=$VERSION bun run dev",
    "build:latest": "cd apps/web && bun run build",
    "build:v": "cd apps/web-v && VERSION=$VERSION bun run build",
    "deploy:latest": "cd apps/web && bun run prepare-content && NODE_OPTIONS='--max-old-space-size=8192' bun run astro build && bunx wrangler deploy",
    "deploy:v": "cd apps/web-v && VERSION=$VERSION bun run deploy",
    "deploy:router": "cd apps/router && bun run deploy",
    "translate": "pnpm --filter @next-i18n/translate start",
    "tampermonkey:dev": "pnpm --filter @next-i18n/tampermonkey dev",
    "tampermonkey:build": "pnpm --filter @next-i18n/tampermonkey build",
    "crawler": "node packages/crawler/dist/index.js"
  },
  "keywords": [],
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "tsx": "^4.19.4"
  },
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
