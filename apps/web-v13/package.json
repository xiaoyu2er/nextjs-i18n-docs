{
  "name": "@next-i18n/web-v13",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run prepare-content && astro dev",
    "prepare-content": "bun run ../../scripts/prepare-content.ts --target apps/web-v13 --version 13",
    "prebuild": "bun run prepare-content",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.34.3",
    "astro": "^5.8.0"
  },
  "devDependencies": {
    "wrangler": "^4.73.0"
  }
}
